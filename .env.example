# =============================================================================
# Telegram Web Scraper — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env file — it is already in .gitignore.
# =============================================================================

# ── Telegram ──────────────────────────────────────────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Google AI (Gemini) ────────────────────────────────────────────────────────
# Get your API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Airtable ─────────────────────────────────────────────────────────────────
# Get your Personal Access Token from https://airtable.com/create/tokens
AIRTABLE_API_KEY=your_airtable_personal_access_token_here

# Your Airtable Base ID (found in the base URL: airtable.com/appXXXXXXXX/...)
AIRTABLE_BASE_ID=your_airtable_base_id_here

# The exact Table ID or Name where leads will be stored
AIRTABLE_TABLE_NAME=your_airtable_table_name_here
